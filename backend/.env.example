# ─── Backend Environment Variables ───────────────────────────────
# Copy this file to ".env" and fill in your real values:
#   cp .env.example .env

# MongoDB connection string.
# Local install:   mongodb://127.0.0.1:27017/tank_database
# MongoDB Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tank_database?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/tank_database

# Port the Express API listens on.
PORT=5000

# Comma-separated list of origins allowed to call the API (the Vite dev server).
CLIENT_ORIGIN=http://localhost:5173
